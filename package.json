{
  "name": "mr-viewer",
  "displayName": "MR Viewer",
  "description": "Merge request viewer",
  "version": "0.2.0",
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mrReview.openPanel",
        "title": "MR Review: Open panel",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "mrReview.openDiff",
        "title": "MR Review: Show file diff"
      },
      {
        "command": "mrReview.refresh",
        "title": "MR Review: Refresh",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mrReview",
          "title": "MR Review",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "mrReview": [
        {
          "id": "mrReview.branchCompare",
          "name": "Compare branch",
          "type": "webview"
        },
        {
          "id": "mrReview.changedFiles",
          "name": "Changed files",
          "when": "mrReview.hasComparison"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "mrReview.refresh",
          "when": "view == mrReview.changedFiles",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
